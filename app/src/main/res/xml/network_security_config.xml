<?xml version="1.0" encoding="utf-8"?>
<!--
  This is a self-hosted app: the server address is user-entered at login (see
  docs/adr/0002-network-auth-architecture.md) and typically points at a LAN/Docker deployment
  over plain HTTP, so the domain can't be allowlisted ahead of time. Android blocks cleartext
  traffic by default since API 28; this opts back in for all destinations.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
